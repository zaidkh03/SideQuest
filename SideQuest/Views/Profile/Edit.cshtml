@model ProfileEditViewModel

<partial name="_PageHeader" model="@(new PageHeaderViewModel
{
    Eyebrow = Model.RoleLabel,
    Title = "Edit profile",
    Subtitle = "Update your account, contact, photo, and public profile details.",
    ActionText = "Back to Profile",
    ActionUrl = Url.Action("Index", "Profile"),
    ActionIcon = "arrow_back"
})" />

<form class="sq-panel sq-verification-form" method="post">
    <div asp-validation-summary="ModelOnly" class="sq-validation-summary"></div>
    <input asp-for="RoleLabel" type="hidden" />

    <div class="sq-section-heading">
        <div>
            <span class="sq-eyebrow">Account</span>
            <h2>Main info</h2>
        </div>
    </div>

    <div class="sq-form-grid">
        <div class="sq-field">
            <label asp-for="FullName"></label>
            <input asp-for="FullName" />
            <span asp-validation-for="FullName" class="sq-field-validation"></span>
        </div>
        <div class="sq-field">
            <label asp-for="PhoneNumber"></label>
            <input asp-for="PhoneNumber" />
            <span asp-validation-for="PhoneNumber" class="sq-field-validation"></span>
        </div>
        <div class="sq-field">
            <label asp-for="DateOfBirth"></label>
            <input asp-for="DateOfBirth" type="date" />
            <span asp-validation-for="DateOfBirth" class="sq-field-validation"></span>
        </div>
        <div class="sq-field">
            <label asp-for="ProfileImageUrl"></label>
            <input asp-for="ProfileImageUrl" />
            <span asp-validation-for="ProfileImageUrl" class="sq-field-validation"></span>
        </div>
    </div>

    @if (User.IsInRole(SideQuest.Authorization.SideQuestRoles.Worker))
    {
        <div class="sq-form-section">
            <div class="sq-section-heading">
                <div>
                    <span class="sq-eyebrow">Worker</span>
                    <h2>Public worker profile</h2>
                </div>
                <a class="sq-link-button" asp-action="Skills">Skills</a>
            </div>
            <div class="sq-form-grid">
                <div class="sq-field">
                    <label asp-for="Worker.Headline"></label>
                    <input asp-for="Worker.Headline" />
                    <span asp-validation-for="Worker.Headline" class="sq-field-validation"></span>
                </div>
                <div class="sq-field">
                    <label asp-for="Worker.Location"></label>
                    <input asp-for="Worker.Location" />
                    <span asp-validation-for="Worker.Location" class="sq-field-validation"></span>
                </div>
                <div class="sq-field">
                    <label asp-for="Worker.HourlyRatePreference"></label>
                    <input asp-for="Worker.HourlyRatePreference" type="number" min="0" step="0.01" />
                </div>
                <div class="sq-field">
                    <label asp-for="Worker.AvailabilityStatus"></label>
                    <select asp-for="Worker.AvailabilityStatus" asp-items="Html.GetEnumSelectList<AvailabilityStatus>()"></select>
                </div>
                <div class="sq-field">
                    <label asp-for="Worker.PortfolioUrl"></label>
                    <input asp-for="Worker.PortfolioUrl" />
                </div>
                <div class="sq-field">
                    <label asp-for="Worker.ResumeUrl"></label>
                    <input asp-for="Worker.ResumeUrl" />
                </div>
                <div class="sq-field">
                    <label asp-for="Worker.ExperienceYears"></label>
                    <input asp-for="Worker.ExperienceYears" type="number" min="0" />
                </div>
                <div class="sq-field sq-field--wide">
                    <label asp-for="Worker.Bio"></label>
                    <textarea asp-for="Worker.Bio" rows="6"></textarea>
                    <span asp-validation-for="Worker.Bio" class="sq-field-validation"></span>
                </div>
            </div>
        </div>
    }

    @if (User.IsInRole(SideQuest.Authorization.SideQuestRoles.Employer))
    {
        <div class="sq-form-section">
            <div class="sq-section-heading">
                <div>
                    <span class="sq-eyebrow">Company</span>
                    <h2>Public company profile</h2>
                </div>
            </div>
            <div class="sq-form-grid">
                <div class="sq-field">
                    <label asp-for="Company.CompanyName"></label>
                    <input asp-for="Company.CompanyName" />
                    <span asp-validation-for="Company.CompanyName" class="sq-field-validation"></span>
                </div>
                <div class="sq-field">
                    <label asp-for="Company.Location"></label>
                    <input asp-for="Company.Location" />
                    <span asp-validation-for="Company.Location" class="sq-field-validation"></span>
                </div>
                <div class="sq-field">
                    <label asp-for="Company.Website"></label>
                    <input asp-for="Company.Website" />
                </div>
                <div class="sq-field">
                    <label asp-for="Company.LogoUrl"></label>
                    <input asp-for="Company.LogoUrl" />
                </div>
                <div class="sq-field sq-field--wide">
                    <label asp-for="Company.Description"></label>
                    <textarea asp-for="Company.Description" rows="6"></textarea>
                    <span asp-validation-for="Company.Description" class="sq-field-validation"></span>
                </div>
            </div>
        </div>
    }

    <div class="sq-form-actions">
        <button class="sq-button sq-button--primary" type="submit">
            <span class="material-symbols-outlined" aria-hidden="true">save</span>
            Save profile
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
