@model WorkerJobsPageViewModel

<partial name="_PageHeader" model="@(new PageHeaderViewModel
{
    Eyebrow = "Worker Portal",
    Title = "Quest board",
    Subtitle = "Browse open quests, filter by category or budget type, and apply when a job fits."
})" />

<form class="sq-panel sq-filter-bar" method="get">
    <div class="sq-field">
        <label for="search">Search</label>
        <input id="search" name="search" value="@Model.Search" placeholder="Title or description" />
    </div>
    <div class="sq-field">
        <label for="categoryId">Category</label>
        <select id="categoryId" name="categoryId">
            <option value="">All categories</option>
            @foreach (var category in Model.Categories)
            {
                <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">@category.Name</option>
            }
        </select>
    </div>
    <div class="sq-form-actions sq-form-actions--inline">
        <button class="sq-button sq-button--primary" type="submit">
            <span class="material-symbols-outlined" aria-hidden="true">search</span>
            Filter
        </button>
        <a class="sq-button sq-button--ghost" asp-action="Jobs">Reset</a>
    </div>
</form>

@if (Model.Jobs.Count == 0)
{
    <div class="sq-empty-state">
        <span class="material-symbols-outlined" aria-hidden="true">explore</span>
        <h3>No open quests match this search</h3>
        <p>Try another keyword or clear filters to see all currently open jobs.</p>
    </div>
}
else
{
    <section class="sq-quest-list sq-quest-list--cards">
        @foreach (var job in Model.Jobs)
        {
            <article class="sq-quest-card">
                <div class="sq-quest-card__top">
                    <span class="sq-badge">@job.CategoryName</span>
                    <strong>@job.RewardLabel</strong>
                </div>
                <h3>@job.Title</h3>
                <p>@job.CompanyName</p>
                <p>@(job.Description.Length > 150 ? $"{job.Description[..150]}..." : job.Description)</p>
                <div class="sq-quest-card__meta">
                    <span>
                        <span class="material-symbols-outlined" aria-hidden="true">group</span>
                        @job.AcceptedWorkers/@job.WorkersNeeded hired
                    </span>
                    <span>
                        <span class="material-symbols-outlined" aria-hidden="true">event</span>
                        @job.StartDate.ToLocalTime().ToString("MMM d")
                    </span>
                </div>
                <a class="sq-button sq-button--ghost sq-button--block" asp-action="Job" asp-route-id="@job.Id">View quest</a>
            </article>
        }
    </section>
}
