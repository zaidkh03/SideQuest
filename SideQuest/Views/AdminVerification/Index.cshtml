@model VerificationQueueViewModel
@{
    var stats = new[]
    {
        new StatCardViewModel
        {
            Label = "Worker Requests",
            Value = Model.SubmittedWorkers.ToString(),
            Detail = "Submitted and waiting",
            Icon = "engineering",
            Accent = "secondary"
        },
        new StatCardViewModel
        {
            Label = "Company Requests",
            Value = Model.SubmittedCompanies.ToString(),
            Detail = "Submitted and waiting",
            Icon = "business_center",
            Accent = "primary"
        },
        new StatCardViewModel
        {
            Label = "Approved",
            Value = Model.ApprovedRequests.ToString(),
            Detail = "Verified profiles",
            Icon = "verified",
            Accent = "secondary"
        },
        new StatCardViewModel
        {
            Label = "Rejected",
            Value = Model.RejectedRequests.ToString(),
            Detail = "Closed requests",
            Icon = "block",
            Accent = "tertiary"
        }
    };
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel
{
    Eyebrow = "Admin Review",
    Title = "Verification queue",
    Subtitle = "Review submitted Worker and Company onboarding requests before portal roles are granted."
})" />

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="sq-alert sq-alert--success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="sq-alert sq-alert--danger">@errorMessage</div>
}

<section class="sq-stat-grid sq-stat-grid--four">
    @foreach (var stat in stats)
    {
        <partial name="_StatCard" model="stat" />
    }
</section>

<section class="sq-equal-grid">
    <article class="sq-panel">
        <div class="sq-section-heading">
            <div>
                <span class="sq-eyebrow">Workers</span>
                <h2>Worker approvals</h2>
            </div>
            <a class="sq-button sq-button--ghost sq-button--sm" asp-action="Workers">Open queue</a>
        </div>
        @if (Model.Workers.Count == 0)
        {
            <div class="sq-compact-empty">No worker verification requests are waiting right now.</div>
        }
        else
        {
            <div class="sq-table-wrap">
                <table class="sq-table">
                    <thead>
                        <tr>
                            <th>Worker</th>
                            <th>Profile</th>
                            <th>Submitted</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var worker in Model.Workers.Take(6))
                        {
                            <tr>
                                <td><strong>@worker.UserName</strong><span>@worker.Email</span></td>
                                <td><strong>@worker.Headline</strong><span>@worker.Location</span></td>
                                <td>@(worker.SubmittedAt?.ToLocalTime().ToString("MMM d, h:mm tt") ?? "Unknown")</td>
                                <td><a class="sq-button sq-button--ghost sq-button--sm" asp-action="Worker" asp-route-id="@worker.ProfileId">Review</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>

    <article class="sq-panel">
        <div class="sq-section-heading">
            <div>
                <span class="sq-eyebrow">Companies</span>
                <h2>Company approvals</h2>
            </div>
            <a class="sq-button sq-button--ghost sq-button--sm" asp-action="Companies">Open queue</a>
        </div>
        @if (Model.Companies.Count == 0)
        {
            <div class="sq-compact-empty">No company verification requests are waiting right now.</div>
        }
        else
        {
            <div class="sq-table-wrap">
                <table class="sq-table">
                    <thead>
                        <tr>
                            <th>Company</th>
                            <th>Owner</th>
                            <th>Submitted</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var company in Model.Companies.Take(6))
                        {
                            <tr>
                                <td><strong>@company.CompanyName</strong><span>@company.Location</span></td>
                                <td><strong>@company.UserName</strong><span>@company.Email</span></td>
                                <td>@(company.SubmittedAt?.ToLocalTime().ToString("MMM d, h:mm tt") ?? "Unknown")</td>
                                <td><a class="sq-button sq-button--ghost sq-button--sm" asp-action="Company" asp-route-id="@company.ProfileId">Review</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>
</section>
