@model VerificationListPageViewModel

<partial name="_PageHeader" model="@(new PageHeaderViewModel
{
    Eyebrow = "Admin Review",
    Title = "Worker verification queue",
    Subtitle = "Search and review worker onboarding requests across every verification status.",
    ActionText = "Back to Summary",
    ActionUrl = Url.Action("Index", "AdminVerification"),
    ActionIcon = "arrow_back"
})" />

<form class="sq-panel sq-filter-bar" method="get">
    <div class="sq-field">
        <label for="search">Search</label>
        <input id="search" name="search" value="@Model.Search" />
    </div>
    <div class="sq-field">
        <label for="status">Status</label>
        <select id="status" name="status">
            <option value="">Any status</option>
            @foreach (var status in Enum.GetValues<VerificationStatus>())
            {
                <option value="@status" selected="@(Model.Status == status)">@status</option>
            }
        </select>
    </div>
    <div class="sq-form-actions sq-form-actions--inline">
        <button class="sq-button sq-button--primary" type="submit">Filter</button>
        <a class="sq-button sq-button--ghost" asp-action="Workers">Reset</a>
    </div>
</form>

<section class="sq-panel">
    @if (Model.Workers.Count == 0)
    {
        <div class="sq-compact-empty">No worker requests match this filter.</div>
    }
    else
    {
        <div class="sq-table-wrap">
            <table class="sq-table">
                <thead>
                    <tr>
                        <th>Worker</th>
                        <th>Profile</th>
                        <th>ID</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Reviewed</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var worker in Model.Workers)
                    {
                        <tr>
                            <td><strong>@worker.UserName</strong><span>@worker.Email</span></td>
                            <td><strong>@worker.Headline</strong><span>@worker.Location</span></td>
                            <td><span class="sq-status">@worker.MaskedNationalId</span></td>
                            <td><span class="sq-status @(worker.Status == VerificationStatus.Approved ? "is-success" : worker.Status == VerificationStatus.Rejected ? "is-danger" : "")">@worker.Status</span></td>
                            <td>@(worker.SubmittedAt?.ToLocalTime().ToString("MMM d, yyyy") ?? "Not submitted")</td>
                            <td>@(worker.ReviewedAt?.ToLocalTime().ToString("MMM d, yyyy") ?? "Not reviewed")</td>
                            <td><a class="sq-button sq-button--ghost sq-button--sm" asp-action="Worker" asp-route-id="@worker.ProfileId">Review</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
