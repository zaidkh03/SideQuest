@model CompanyProfilePageViewModel

<partial name="_PageHeader" model="@(new PageHeaderViewModel
{
    Eyebrow = "Employer Portal",
    Title = "Company profile",
    Subtitle = "Keep your company identity clear for workers reviewing your quests."
})" />

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="sq-alert sq-alert--success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="sq-alert sq-alert--danger">@errorMessage</div>
}

<section class="sq-dashboard-grid">
    <div class="sq-dashboard-main">
        <form class="sq-panel sq-verification-form" method="post">
            <div asp-validation-summary="ModelOnly" class="sq-validation-summary"></div>
            <div class="sq-form-grid">
                <div class="sq-field">
                    <label asp-for="Form.CompanyName"></label>
                    <input asp-for="Form.CompanyName" name="CompanyName" />
                    <span asp-validation-for="Form.CompanyName" class="sq-field-validation"></span>
                </div>
                <div class="sq-field">
                    <label asp-for="Form.Location"></label>
                    <input asp-for="Form.Location" name="Location" />
                    <span asp-validation-for="Form.Location" class="sq-field-validation"></span>
                </div>
                <div class="sq-field">
                    <label asp-for="Form.Website"></label>
                    <input asp-for="Form.Website" name="Website" />
                    <span asp-validation-for="Form.Website" class="sq-field-validation"></span>
                </div>
                <div class="sq-field">
                    <label asp-for="Form.LogoUrl"></label>
                    <input asp-for="Form.LogoUrl" name="LogoUrl" />
                    <span asp-validation-for="Form.LogoUrl" class="sq-field-validation"></span>
                </div>
                <div class="sq-field sq-field--wide">
                    <label asp-for="Form.Description"></label>
                    <textarea asp-for="Form.Description" name="Description" rows="6"></textarea>
                    <span asp-validation-for="Form.Description" class="sq-field-validation"></span>
                </div>
            </div>
            <div class="sq-form-actions">
                <button class="sq-button sq-button--primary" type="submit">
                    <span class="material-symbols-outlined" aria-hidden="true">save</span>
                    Save company
                </button>
            </div>
        </form>
    </div>
    <aside class="sq-dashboard-side">
        <div class="sq-panel sq-plan-card">
            <span class="sq-eyebrow">Verification</span>
            <h2>@Model.VerificationStatus</h2>
            <p>@(Model.IsVerified ? "This company is verified and can post quests." : "Verification status controls employer access.")</p>
        </div>
        <div class="sq-panel sq-plan-card">
            <span class="sq-eyebrow">Subscription</span>
            <h2>@(Model.ActiveSubscription?.PlanName ?? "No active plan")</h2>
            <p>@(Model.ActiveSubscription is null ? "Approved companies receive a starter subscription." : $"{Model.ActiveSubscription.JobLimitPerMonth} jobs per month · {Model.ActiveSubscription.CommissionRate:0.##}% commission")</p>
        </div>
    </aside>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
