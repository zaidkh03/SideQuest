@model CommunityIndexViewModel

<partial name="_PageHeader" model="@(new PageHeaderViewModel
{
    Eyebrow = "Community",
    Title = "Community board",
    Subtitle = "Share updates, questions, events, and opportunities with the SideQuest network."
})" />

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="sq-alert sq-alert--success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="sq-alert sq-alert--danger">@errorMessage</div>
}

<section class="sq-social-feed">
    <div class="sq-section-heading">
        <div>
            <span class="sq-eyebrow">Feed</span>
            <h2>Latest posts</h2>
        </div>
        <button class="sq-button sq-button--primary" type="button" data-bs-toggle="modal" data-bs-target="#postCreateModal">
            <span class="material-symbols-outlined" aria-hidden="true">edit_square</span>
            Create post
        </button>
    </div>

    @if (Model.Posts.Count == 0)
    {
        <div class="sq-empty-state">
            <span class="material-symbols-outlined" aria-hidden="true">forum</span>
            <h3>No community posts yet</h3>
            <p>Create the first post for workers, employers, and admins to discuss.</p>
        </div>
    }
    else
    {
        @foreach (var post in Model.Posts)
        {
            <article class="sq-panel sq-social-post">
                <div class="sq-social-post__author">
                    <span class="sq-avatar">@post.AuthorInitials</span>
                    <div>
                        <h2>@post.AuthorName</h2>
                        <p>@post.Type · @post.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</p>
                    </div>
                </div>
                <h3 class="sq-social-post__title">@post.Title</h3>
                <p class="sq-muted-text">@post.ContentPreview</p>
                <div class="sq-social-actions">
                    <form asp-action="ToggleLike" asp-route-id="@post.Id" method="post">
                        <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                        <button class="sq-button sq-button--ghost sq-button--sm" type="submit">
                            <span class="material-symbols-outlined" aria-hidden="true">thumb_up</span>
                            @(post.IsLikedByCurrentUser ? "Liked" : "Like") · @post.LikeCount
                        </button>
                    </form>
                    <a class="sq-button sq-button--ghost sq-button--sm" asp-action="Details" asp-route-id="@post.Id">
                        <span class="material-symbols-outlined" aria-hidden="true">chat</span>
                        Comments · @post.CommentCount
                    </a>
                </div>
            </article>
        }
    }
</section>

<div class="modal fade sq-modal" id="postCreateModal" tabindex="-1" aria-labelledby="postCreateTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header">
                    <div>
                        <span class="sq-eyebrow">Create</span>
                        <h2 class="modal-title" id="postCreateTitle">New post</h2>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body sq-verification-form">
                    <div class="sq-field">
                        <label asp-for="Form.Type"></label>
                        <select asp-for="Form.Type" asp-items="Html.GetEnumSelectList<CommunityPostType>()"></select>
                    </div>
                    <div class="sq-field">
                        <label asp-for="Form.Title"></label>
                        <input asp-for="Form.Title" />
                        <span asp-validation-for="Form.Title" class="sq-field-validation"></span>
                    </div>
                    <div class="sq-field">
                        <label asp-for="Form.Content"></label>
                        <textarea asp-for="Form.Content" rows="6"></textarea>
                        <span asp-validation-for="Form.Content" class="sq-field-validation"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="sq-button sq-button--ghost" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="sq-button sq-button--primary" type="submit">
                        <span class="material-symbols-outlined" aria-hidden="true">send</span>
                        Publish
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
