@model AchievementAdminPageViewModel

<partial name="_PageHeader" model="@(new PageHeaderViewModel
{
    Eyebrow = "Admin Portal",
    Title = "Achievements",
    Subtitle = "Manage XP thresholds and badge records for worker progression."
})" />

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="sq-alert sq-alert--success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="sq-alert sq-alert--danger">@errorMessage</div>
}

<section class="sq-dashboard-grid">
    <div class="sq-dashboard-main">
        <div class="sq-panel">
            <div class="sq-table-wrap">
                <table class="sq-table">
                    <thead>
                        <tr>
                            <th>Achievement</th>
                            <th>XP</th>
                            <th>Badge</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var achievement in Model.Achievements)
                        {
                            <tr>
                                <td>
                                    <strong>@achievement.Name</strong>
                                    <span>@achievement.Description</span>
                                </td>
                                <td>@achievement.XPRequired</td>
                                <td>@achievement.BadgeImageUrl</td>
                                <td><a class="sq-button sq-button--ghost sq-button--sm" asp-action="Achievements" asp-route-editId="@achievement.Id">Edit</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <aside class="sq-dashboard-side">
        <form class="sq-panel sq-plan-card" asp-action="SaveAchievement" method="post">
            <input asp-for="Form.Id" type="hidden" name="Id" />
            <span class="sq-eyebrow">@(Model.Form.Id.HasValue ? "Edit" : "Create")</span>
            <h2>Achievement</h2>
            <div class="sq-field">
                <label asp-for="Form.Name"></label>
                <input asp-for="Form.Name" name="Name" />
                <span asp-validation-for="Form.Name" class="sq-field-validation"></span>
            </div>
            <div class="sq-field">
                <label asp-for="Form.XPRequired"></label>
                <input asp-for="Form.XPRequired" name="XPRequired" type="number" min="0" />
                <span asp-validation-for="Form.XPRequired" class="sq-field-validation"></span>
            </div>
            <div class="sq-field">
                <label asp-for="Form.BadgeImageUrl"></label>
                <input asp-for="Form.BadgeImageUrl" name="BadgeImageUrl" />
                <span asp-validation-for="Form.BadgeImageUrl" class="sq-field-validation"></span>
            </div>
            <div class="sq-field">
                <label asp-for="Form.Description"></label>
                <textarea asp-for="Form.Description" name="Description" rows="4"></textarea>
                <span asp-validation-for="Form.Description" class="sq-field-validation"></span>
            </div>
            <button class="sq-button sq-button--primary sq-button--block" type="submit">Save achievement</button>
        </form>
    </aside>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
