@using SideQuest.Authorization
@{
    var activePortal = ViewData["ActivePortal"] as string;
    var hasPortalRole = User.IsInRole(SideQuestRoles.Worker)
        || User.IsInRole(SideQuestRoles.Employer)
        || User.IsInRole(SideQuestRoles.Admin);

    string LinkClass(string portal)
    {
        return string.Equals(activePortal, portal, StringComparison.OrdinalIgnoreCase)
            ? "sq-mobile-nav__link is-active"
            : "sq-mobile-nav__link";
    }
}

<nav class="sq-mobile-nav" aria-label="Mobile portal navigation">
    @if (User.IsInRole(SideQuestRoles.Worker))
    {
        <a class="@LinkClass("Worker")" asp-controller="Dashboard" asp-action="Worker">
            <span class="material-symbols-outlined" aria-hidden="true">dashboard</span>
            <span>Worker</span>
        </a>
        <a class="sq-mobile-nav__link" asp-controller="Worker" asp-action="Jobs">
            <span class="material-symbols-outlined" aria-hidden="true">work</span>
            <span>Jobs</span>
        </a>
        <a class="sq-mobile-nav__link" asp-controller="Worker" asp-action="Applications">
            <span class="material-symbols-outlined" aria-hidden="true">assignment</span>
            <span>Work</span>
        </a>
        <a class="sq-mobile-nav__link" asp-controller="Worker" asp-action="Wallet">
            <span class="material-symbols-outlined" aria-hidden="true">account_balance_wallet</span>
            <span>Wallet</span>
        </a>
    }
    @if (User.IsInRole(SideQuestRoles.Employer))
    {
        <a class="@LinkClass("Employer")" asp-controller="Dashboard" asp-action="Employer">
            <span class="material-symbols-outlined" aria-hidden="true">business_center</span>
            <span>Company</span>
        </a>
        <a class="sq-mobile-nav__link" asp-controller="Employer" asp-action="Jobs">
            <span class="material-symbols-outlined" aria-hidden="true">work</span>
            <span>Jobs</span>
        </a>
    }
    @if (User.IsInRole(SideQuestRoles.Admin))
    {
        <a class="@LinkClass("Admin")" asp-controller="Dashboard" asp-action="Admin">
            <span class="material-symbols-outlined" aria-hidden="true">admin_panel_settings</span>
            <span>Admin</span>
        </a>
        <a class="sq-mobile-nav__link" asp-controller="AdminVerification" asp-action="Index">
            <span class="material-symbols-outlined" aria-hidden="true">fact_check</span>
            <span>Review</span>
        </a>
        <a class="sq-mobile-nav__link" asp-controller="AdminManagement" asp-action="Users">
            <span class="material-symbols-outlined" aria-hidden="true">group</span>
            <span>Users</span>
        </a>
        <a class="sq-mobile-nav__link" asp-controller="AdminManagement" asp-action="Jobs">
            <span class="material-symbols-outlined" aria-hidden="true">work</span>
            <span>Jobs</span>
        </a>
    }
    @if (!hasPortalRole)
    {
        <a class="@LinkClass("Onboarding")" asp-controller="Onboarding" asp-action="Index">
            <span class="material-symbols-outlined" aria-hidden="true">verified_user</span>
            <span>Status</span>
        </a>
    }
</nav>
