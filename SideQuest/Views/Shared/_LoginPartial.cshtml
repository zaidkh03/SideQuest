@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    ApplicationUser? currentUser = null;
    if (SignInManager.IsSignedIn(User))
    {
        currentUser = await UserManager.GetUserAsync(User);
    }

    var displayName = currentUser?.FullName;
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = User.Identity?.Name ?? "Account";
    }

    var initials = string.Join(
        string.Empty,
        displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => part[0]))
        .ToUpperInvariant();
}

<div class="sq-auth-actions">
    @if (SignInManager.IsSignedIn(User))
    {
        <a class="sq-user-chip" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage account">
            <span class="sq-avatar">@initials</span>
            <span class="sq-user-chip__name">@displayName</span>
        </a>
        <form class="sq-logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="sq-link-button">Logout</button>
        </form>
    }
    else
    {
        <a class="sq-nav-pill" asp-area="Identity" asp-page="/Account/Register">Register</a>
        <a class="sq-button sq-button--primary sq-button--sm" asp-area="Identity" asp-page="/Account/Login">Login</a>
    }
</div>
