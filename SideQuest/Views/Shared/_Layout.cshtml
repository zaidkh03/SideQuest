@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@{
    var shell = (ViewData["Shell"] as string) ?? (SignInManager.IsSignedIn(User) ? "App" : "Marketing");
    var isAppShell = string.Equals(shell, "App", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en" class="sq-theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SideQuest</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Plus+Jakarta+Sans:wght@600;700;800&amp;family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,400..600,0..1,0&amp;display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SideQuest.styles.css" asp-append-version="true" />
</head>
<body class="sq-body @(isAppShell ? "sq-body--app" : "sq-body--marketing")">
    @if (isAppShell)
    {
        <div class="sq-app-frame">
            <partial name="_AppSidebar" />
            <div class="sq-app-main">
                <partial name="_TopBar" />
                <main role="main" class="sq-page-shell">
                    @RenderBody()
                </main>
            </div>
            <partial name="_MobileNav" />
        </div>
    }
    else
    {
        <div class="sq-marketing-shell">
            <partial name="_TopBar" />
            <main role="main" class="sq-marketing-main">
                @RenderBody()
            </main>
            <footer class="sq-footer">
                <div class="sq-container sq-footer__inner">
                    <span>&copy; 2026 SideQuest</span>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>
        </div>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
